---
import GalleryLayout from '../layouts/GalleryLayout.astro';
import VariantNav from '../components/VariantNav.astro';
import { variants } from '../data/variants';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return variants.map((v) => ({
    params: { variant: v.slug },
    props: { variant: v },
  }));
};

const { variant } = Astro.props;
---

<GalleryLayout title={variant.name}>
  <section class="detail-header">
    <div class="header-inner">
      <div class="color-swatch" style={`background: ${variant.theme.primaryColor};`}>
        <span class="accent-dot" style={`background: ${variant.theme.accentColor};`}></span>
      </div>
      <div>
        <h1 class="detail-title">{variant.name}</h1>
        <p class="detail-tagline">{variant.tagline}</p>
      </div>
    </div>
  </section>

  <section class="iframe-section">
    <div class="iframe-toolbar">
      <button id="expand-btn" class="pill-btn">Expand Full Screen</button>
    </div>
    <div id="iframe-container" class="iframe-wrapper">
      <iframe
        src={variant.previewUrl}
        title={`Full preview of ${variant.name}`}
        class="detail-iframe"
      ></iframe>
    </div>
    <button id="back-btn" class="pill-btn back-btn">Back to Gallery</button>
  </section>

  <VariantNav currentSlug={variant.slug} />
</GalleryLayout>

<style>
  .detail-header {
    padding: 40px 24px 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .color-swatch {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    position: relative;
    flex-shrink: 0;
  }

  .accent-dot {
    position: absolute;
    bottom: -3px;
    right: -3px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid #09090b;
  }

  .detail-title {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .detail-tagline {
    font-size: 16px;
    color: #71717a;
    margin-top: 2px;
  }

  .iframe-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 16px;
  }

  .iframe-toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 8px;
  }

  .pill-btn {
    background: #27272a;
    color: #e4e4e7;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 8px 16px;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.15s;
  }

  .pill-btn:hover {
    background: #3f3f46;
  }

  .back-btn {
    display: none;
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 101;
  }

  .iframe-wrapper {
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    background: #ffffff;
  }

  .iframe-wrapper.fullscreen {
    position: fixed;
    inset: 0;
    z-index: 100;
    width: 100%;
    height: 100%;
    border-radius: 0;
    border: none;
  }

  .iframe-wrapper.fullscreen .detail-iframe {
    height: 100%;
  }

  .detail-iframe {
    width: 100%;
    height: 80vh;
    border: none;
    display: block;
  }
</style>

<script>
  const expandBtn = document.getElementById('expand-btn') as HTMLButtonElement;
  const backBtn = document.getElementById('back-btn') as HTMLButtonElement;
  const container = document.getElementById('iframe-container') as HTMLDivElement;

  expandBtn.addEventListener('click', () => {
    container.classList.add('fullscreen');
    backBtn.style.display = 'block';
    expandBtn.style.display = 'none';
  });

  backBtn.addEventListener('click', () => {
    container.classList.remove('fullscreen');
    backBtn.style.display = 'none';
    expandBtn.style.display = 'block';
  });
</script>
