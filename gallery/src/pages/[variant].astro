---
import GalleryLayout from '../layouts/GalleryLayout.astro';
import VariantNav from '../components/VariantNav.astro';
import { variants } from '../data/variants';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return variants.map((v) => ({
    params: { variant: v.slug },
    props: { variant: v },
  }));
};

const { variant } = Astro.props;
---

<GalleryLayout title={variant.name}>
  <section class="detail-header">
    <div class="header-inner">
      <div class="color-swatch" style={`background: ${variant.theme.primaryColor};`}>
        <span class="accent-dot" style={`background: ${variant.theme.accentColor};`}></span>
      </div>
      <div>
        <h1 class="detail-title">{variant.name}</h1>
        <p class="detail-tagline">{variant.tagline}</p>
      </div>
    </div>
  </section>

  <section class="iframe-section">
    <div class="iframe-wrapper">
      <iframe
        src={variant.previewUrl}
        title={`Full preview of ${variant.name}`}
        class="detail-iframe"
      ></iframe>
    </div>
  </section>

  <VariantNav currentSlug={variant.slug} />
</GalleryLayout>

<style>
  .detail-header {
    padding: 40px 24px 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .color-swatch {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    position: relative;
    flex-shrink: 0;
  }

  .accent-dot {
    position: absolute;
    bottom: -3px;
    right: -3px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid #09090b;
  }

  .detail-title {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .detail-tagline {
    font-size: 16px;
    color: #71717a;
    margin-top: 2px;
  }

  .iframe-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 16px;
  }

  .iframe-wrapper {
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    background: #ffffff;
  }

  .detail-iframe {
    width: 100%;
    height: 80vh;
    border: none;
    display: block;
  }
</style>
